{
  "expo": {
    "name": "CadNav 2",
    "slug": "cadnav2",
    "scheme": "cadnav",
    "version": "0.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icons/icon.png",
    "splash": {
      "image": "./assets/icons/CadNav.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cadnav.CadNav",
      "icon": "./assets/icons/CadNavIcon.icon",
      "infoPlist": {
        "UIBackgroundModes": [
          "location",
          "fetch"
        ]
      }
    },
    "android": {
      "icon": "./assets/icons/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/foreground.png",
        "backgroundImage": "./assets/icons/background.png",
        "monochromeImage": "./assets/icons/monochromatic.png"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.cadnav.CadNav",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/icons/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow CadNav 2 to use your location for offline navigation and map positioning.",
          "locationAlwaysAndWhenInUsePermission": "Allow CadNav 2 to use your location to record routes and navigate while the app is in the background.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "@maplibre/maplibre-react-native"
    ],
    "assetBundlePatterns": [
      "assets/*"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0d8348a4-8e40-40ea-a5ba-c083b8f8e2b5"
      }
    }
  }
}
